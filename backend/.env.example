# THYN Backend — Environment Variables

# Supabase Project (get these from your Supabase project dashboard → Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database (get DATABASE_URL from Supabase → Settings → Database → Connection string)
# Use the transaction pooler URL for DATABASE_URL and the direct connection for DIRECT_URL
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-xxx.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-xxx.supabase.com:5432/postgres

# Server
PORT=3001
NODE_ENV=development

# CORS (comma-separated, optional — defaults to http://localhost:3000)
CORS_ORIGINS=http://localhost:3000
